# Copy to .env and adjust as needed. These map directly to the settings read
# in app.py (Config.from_env). All values are optional; defaults are shown.

# Stream a synthetic animated feed instead of a real camera (true/false).
# Use this to run the project on a laptop with no Raspberry Pi hardware.
RPS_DEMO_MODE=false

# USB camera device index (/dev/video<N>).
CAMERA_INDEX=0

# Capture resolution and frame rate.
CAMERA_WIDTH=640
CAMERA_HEIGHT=360
CAMERA_FPS=20

# HTTP server binding.
HOST=0.0.0.0
PORT=5000

# Verbose logging (true/false).
DEBUG=false
