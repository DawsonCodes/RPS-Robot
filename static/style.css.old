:root {
  --bg-a: #020814;
  --bg-b: #071325;
  --bg-c: #0d1d36;
  --card: rgba(17, 26, 49, 0.72);
  --card-border: rgba(255, 255, 255, 0.10);
  --text: #f5f7ff;
  --muted: #a8b5d2;
  --blue: #6bb8ff;
  --blue-2: #8cc9ff;
  --pink: #ff5f93;
  --pink-2: #ff7cab;
  --mint: #6ff0d5;
  --shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
  --ring-angle: 0deg;
}

@property --ring-angle {
  syntax: "<angle>";
  inherits: false;
  initial-value: 0deg;
}

* {
  box-sizing: border-box;
}

html, body {
  min-height: 100%;
}

body {
  margin: 0;
  color: var(--text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 18% 20%, rgba(107,184,255,0.12), transparent 24%),
    radial-gradient(circle at 82% 18%, rgba(255,95,147,0.10), transparent 20%),
    radial-gradient(circle at 58% 72%, rgba(111,240,213,0.06), transparent 18%),
    linear-gradient(145deg, var(--bg-a), var(--bg-b) 48%, var(--bg-c));
  overflow-x: hidden;
  position: relative;
}

.space-bg {
  position: fixed;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.stars,
.nebula {
  position: absolute;
  inset: 0;
}

.stars::before,
.stars::after {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(1.5px 1.5px at 8% 14%, rgba(255,255,255,0.95), transparent 60%),
    radial-gradient(2px 2px at 16% 44%, rgba(255,255,255,0.90), transparent 60%),
    radial-gradient(1.5px 1.5px at 24% 28%, rgba(255,255,255,0.80), transparent 60%),
    radial-gradient(2px 2px at 33% 19%, rgba(255,255,255,0.90), transparent 60%),
    radial-gradient(1.5px 1.5px at 42% 52%, rgba(255,255,255,0.85), transparent 60%),
    radial-gradient(2px 2px at 55% 24%, rgba(255,255,255,0.90), transparent 60%),
    radial-gradient(1.5px 1.5px at 64% 13%, rgba(255,255,255,0.78), transparent 60%),
    radial-gradient(2px 2px at 73% 36%, rgba(255,255,255,0.92), transparent 60%),
    radial-gradient(1.5px 1.5px at 84% 20%, rgba(255,255,255,0.82), transparent 60%),
    radial-gradient(2px 2px at 92% 41%, rgba(255,255,255,0.90), transparent 60%),
    radial-gradient(1.5px 1.5px at 12% 78%, rgba(255,255,255,0.88), transparent 60%),
    radial-gradient(2px 2px at 29% 86%, rgba(255,255,255,0.86), transparent 60%),
    radial-gradient(1.5px 1.5px at 47% 74%, rgba(255,255,255,0.80), transparent 60%),
    radial-gradient(2px 2px at 66% 82%, rgba(255,255,255,0.88), transparent 60%),
    radial-gradient(1.5px 1.5px at 88% 76%, rgba(255,255,255,0.84), transparent 60%);
  opacity: 0.95;
}

.stars::before {
  animation: starDriftA 90s linear infinite;
}

.stars::after {
  transform: scale(1.05);
  opacity: 0.50;
  animation: starDriftB 130s linear infinite;
}

.nebula {
  background:
    radial-gradient(circle at 20% 25%, rgba(107,184,255,0.10), transparent 18%),
    radial-gradient(circle at 78% 22%, rgba(255,95,147,0.08), transparent 16%),
    radial-gradient(circle at 58% 72%, rgba(111,240,213,0.06), transparent 18%);
  filter: blur(42px);
  animation: nebulaShift 16s ease-in-out infinite alternate;
}

.shell {
  width: min(1380px, calc(100% - 32px));
  margin: 0 auto;
  padding: 28px 0 40px;
  position: relative;
  z-index: 1;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: flex-start;
  margin-bottom: 22px;
}

.eyebrow {
  margin-bottom: 10px;
  color: var(--mint);
  letter-spacing: .12em;
  text-transform: uppercase;
  font-size: .82rem;
}

h1 {
  margin: 0;
  font-size: clamp(2rem, 5vw, 3.35rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  text-shadow: 0 0 20px rgba(107,184,255,0.12);
}

.subtitle {
  margin: 12px 0 0;
  max-width: 860px;
  color: var(--muted);
  line-height: 1.65;
}

.status-pill {
  align-self: center;
  padding: 12px 16px;
  border-radius: 999px;
  background: rgba(107,184,255,0.10);
  border: 1px solid rgba(107,184,255,0.26);
  box-shadow: var(--shadow);
  white-space: nowrap;
  backdrop-filter: blur(12px);
}

.layout {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(340px, 0.75fr);
  gap: 20px;
  align-items: start;
}

.camera-card {
  min-width: 0;
}

.game-card {
  min-width: 0;
}

.card {
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 28px;
  padding: 20px;
  backdrop-filter: blur(18px);
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.04), transparent 22%),
    radial-gradient(circle at top left, rgba(107,184,255,0.10), transparent 24%),
    radial-gradient(circle at top right, rgba(255,95,147,0.07), transparent 22%);
}

.card-head,
.detection-row,
.arena,
.actions,
.score-grid,
.result-panel {
  position: relative;
  z-index: 1;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.card-head h2 {
  margin: 0;
  font-size: 1.18rem;
}

.note {
  color: var(--muted);
  font-size: .92rem;
}

.video-frame {
  border-radius: 22px;
  overflow: hidden;
  background: #01050d;
  border: 1px solid rgba(255,255,255,0.08);
  position: relative;
  z-index: 1;
  aspect-ratio: 16 / 9;
}

.video-frame video {
  display: block;
  width: 100%;
  height: 100%;
  background: #000;
  object-fit: cover;
  filter: saturate(1.03) contrast(1.03);
}

.detection-row {
  margin-top: 16px;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
}

.tiny-label {
  color: var(--muted);
  font-size: .9rem;
  margin-bottom: 6px;
}

.detected-text {
  font-size: 1.2rem;
  font-weight: 800;
  letter-spacing: .05em;
}

.confidence-box {
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(111,240,213,0.10);
  border: 1px solid rgba(111,240,213,0.20);
  color: #ddfff8;
  font-weight: 700;
  text-align: center;
  backdrop-filter: blur(10px);
}

.arena {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 16px;
  align-items: center;
  margin-top: 8px;
}

.player-box {
  padding: 18px;
  text-align: center;
  border-radius: 24px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
}

.player-box.glow {
  background: linear-gradient(180deg, rgba(107,184,255,0.10), rgba(255,95,147,0.05));
  border-color: rgba(107,184,255,0.18);
}

.player-name {
  color: var(--muted);
  margin-bottom: 10px;
}

.hand {
  user-select: none;
  line-height: 1;
}

.hand.big {
  font-size: 4.25rem;
  margin: 12px 0;
}

.hand.huge {
  font-size: 5.4rem;
  margin: 10px 0 14px;
}

.move-label {
  font-weight: 800;
  font-size: 1.02rem;
}

.versus {
  color: var(--muted);
  font-weight: 900;
  letter-spacing: .15em;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 170px;
  gap: 12px;
  margin-top: 22px;
}

button {
  position: relative;
  isolation: isolate;
  border: 0;
  border-radius: 18px;
  padding: 16px 18px;
  cursor: pointer;
  color: white;
  font-size: 1rem;
  font-weight: 800;
  transition: transform .15s ease, opacity .15s ease, box-shadow .18s ease;
  box-shadow: var(--shadow);
}

button::before {
  content: "";
  position: absolute;
  inset: -3px;
  border-radius: 21px;
  padding: 3px;
  background: conic-gradient(
    from var(--ring-angle),
    var(--blue) 0deg,
    var(--blue-2) 70deg,
    var(--pink) 180deg,
    var(--pink-2) 250deg,
    var(--blue) 360deg
  );
  opacity: 0;
  transition: opacity .18s ease;
  animation: ringOrbit 1.35s linear infinite;
  z-index: -2;
  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
          mask-composite: exclude;
}

button::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 18px;
  z-index: -1;
}

button:hover,
button:focus-visible {
  transform: translateY(-1px);
}

button:hover::before,
button:focus-visible::before {
  opacity: 1;
}

#playBtn {
  background: linear-gradient(135deg, rgba(126,166,255,0.95), rgba(158,124,255,0.90));
}

#playBtn::after {
  background: linear-gradient(135deg, rgba(126,166,255,0.95), rgba(158,124,255,0.90));
}

button.ghost {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
}

button.ghost::after {
  background: rgba(255,255,255,0.08);
}

button:disabled {
  opacity: .7;
  cursor: not-allowed;
  transform: none;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: 18px;
}

.score-card {
  border-radius: 20px;
  padding: 14px 16px;
  background: rgba(0,0,0,0.18);
  border: 1px solid rgba(255,255,255,0.08);
  text-align: center;
  backdrop-filter: blur(10px);
}

.score-card span {
  display: block;
  color: var(--muted);
  margin-bottom: 6px;
}

.score-card strong {
  font-size: 1.6rem;
}

.result-panel {
  margin-top: 18px;
  padding: 18px;
  border-radius: 22px;
  background: rgba(0,0,0,0.18);
  border: 1px solid rgba(255,255,255,0.08);
  min-height: 88px;
  backdrop-filter: blur(10px);
}

.bounce {
  animation: bounce .22s ease;
}

@keyframes bounce {
  0%   { transform: translateY(0); }
  50%  { transform: translateY(-10px); }
  100% { transform: translateY(0); }
}

@keyframes ringOrbit {
  to { --ring-angle: 360deg; }
}

@keyframes starDriftA {
  0%   { transform: translate3d(0, 0, 0); }
  100% { transform: translate3d(-35px, 18px, 0); }
}

@keyframes starDriftB {
  0%   { transform: translate3d(0, 0, 0); }
  100% { transform: translate3d(26px, -14px, 0); }
}

@keyframes nebulaShift {
  0%   { transform: scale(1) translate3d(0, 0, 0); }
  100% { transform: scale(1.05) translate3d(14px, -10px, 0); }
}

@media (max-width: 1080px) {
  .layout {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 950px) {
  .hero {
    flex-direction: column;
  }

  .status-pill {
    align-self: flex-start;
  }

  .arena {
    grid-template-columns: 1fr;
  }

  .versus {
    text-align: center;
  }

  .actions {
    grid-template-columns: 1fr;
  }
}

/* Impossible Mode toggle */
.mode-btn {
  margin-top: 10px;
  width: 100%;
  font-size: 0.92rem;
  padding: 12px 14px;
  background: rgba(111,240,213,0.10);
  border: 1px solid rgba(111,240,213,0.20);
  color: #ddfff8;
}
.mode-btn::after {
  background: rgba(111,240,213,0.10);
}
.mode-btn.impossible {
  background: linear-gradient(135deg, rgba(255,95,147,0.35), rgba(255,124,171,0.25));
  border-color: rgba(255,95,147,0.45);
  color: #ffe5ef;
}
.mode-btn.impossible::after {
  background: linear-gradient(135deg, rgba(255,95,147,0.35), rgba(255,124,171,0.25));
}
