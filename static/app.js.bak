import {
  FilesetResolver,
  GestureRecognizer
} from "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@latest/vision_bundle.mjs";

const statusPill = document.getElementById("statusPill");
const piStream = document.getElementById("piStream");
const analysisCanvas = document.getElementById("analysisCanvas");
const ctx = analysisCanvas.getContext("2d", { willReadFrequently: true });

const moveOverlay = document.getElementById("moveOverlay");
const detectedMove = document.getElementById("detectedMove");
const gestureDetail = document.getElementById("gestureDetail");
const userHand = document.getElementById("userHand");
const userMoveLabel = document.getElementById("userMoveLabel");
const computerHand = document.getElementById("computerHand");
const computerMoveLabel = document.getElementById("computerMoveLabel");
const playBtn = document.getElementById("playBtn");
const resetBtn = document.getElementById("resetBtn");
const modeBtn = document.getElementById("modeBtn");
const resultText = document.getElementById("resultText");
const winsCount = document.getElementById("winsCount");
const lossesCount = document.getElementById("lossesCount");
const drawsCount = document.getElementById("drawsCount");

const emojiMap = { rock: "✊", paper: "✋", scissors: "✌️", unknown: "❔", "no hand": "❔" };
const COUNTERS = { rock: "paper", paper: "scissors", scissors: "rock" };

const DETECT_INTERVAL_MS = 70;
const DETECT_WIDTH = 320;
const LOCK_HOLD_MS = 180;
const RELEASE_AFTER_MS = 350;

let pc = null;
let gestureRecognizer = null;
let detectorReady = false;
let lastInferTime = 0;
let roundBusy = false;
let currentMove = "no hand";
let lastCandidate = "no hand";
let candidateSince = 0;
let lastCleanLockAt = 0;
let lastHandSeenAt = 0;
let impossibleMode = false;
const score = { wins: 0, losses: 0, draws: 0 };

function prettyMove(m) {
  if (m === "unknown") return "HAND SEEN";
  if (m === "no hand") return "NO HAND";
  return m.toUpperCase();
}

function setUserMove(m) {
  userHand.textContent = emojiMap[m] || "❔";
  userMoveLabel.textContent = m === "unknown" ? "hand seen" : m === "no hand" ? "show your hand" : prettyMove(m);
}

function setComputerMove(m) {
  computerHand.textContent = emojiMap[m] || "❔";
  computerMoveLabel.textContent = m === "no hand" ? "press play" : prettyMove(m);
}

function updateScore() {
  winsCount.textContent = String(score.wins);
  lossesCount.textContent = String(score.losses);
  drawsCount.textContent = String(score.draws);
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function decideWinner(u, c) {
  if (u === c) return "draw";
  return COUNTERS[c] === u ? "lose" : "win";
}

function resultMessage(r, u, c) {
  if (r === "draw") return `Draw. You both picked ${prettyMove(u)}.`;
  if (r === "win") return `You win. ${prettyMove(u)} beats ${prettyMove(c)}.`;
  return `Computer wins. ${prettyMove(c)} beats ${prettyMove(u)}.`;
}

function setMode(impossible) {
  impossibleMode = impossible;
  if (modeBtn) {
    modeBtn.textContent = impossible ? "MODE: IMPOSSIBLE" : "MODE: FAIR";
    modeBtn.classList.toggle("impossible", impossible);
  }
}

async function animateComputer(finalMove) {
  const seq = ["rock", "paper", "scissors", "rock", "paper", "scissors", finalMove];
  for (const m of seq) {
    computerHand.textContent = emojiMap[m];
    computerMoveLabel.textContent = prettyMove(m);
    computerHand.classList.remove("bounce");
    void computerHand.offsetWidth;
    computerHand.classList.add("bounce");
    await sleep(150);
  }
}

// === DUAL CLASSIFIER: gesture recognizer + landmark fallback ===
function dist(a, b) {
  return Math.hypot(a.x - b.x, a.y - b.y);
}

function classifyFromLandmarks(lm) {
  function isExtended(tipIdx, mcpIdx) {
    return dist(lm[tipIdx], lm[0]) > dist(lm[mcpIdx], lm[0]) * 1.22;
  }
  const idx = isExtended(8, 5);
  const mid = isExtended(12, 9);
  const ring = isExtended(16, 13);
  const pinky = isExtended(20, 17);
  const ext = [idx, mid, ring, pinky].filter(Boolean).length;

  // Just count fingers - super forgiving
  if (ext >= 3) return { move: "paper", source: "lm" };
  if (ext === 2) return { move: "scissors", source: "lm" };
  return { move: "rock", source: "lm" };
}

function classify(result) {
  const lm = result?.landmarks?.[0];
  const g = result?.gestures?.[0]?.[0];

  if (g && g.score >= 0.55) {
    if (g.categoryName === "Closed_Fist") return { move: "rock", source: "gesture", debug: `${g.categoryName} ${(g.score*100).toFixed(0)}%` };
    if (g.categoryName === "Open_Palm") return { move: "paper", source: "gesture", debug: `${g.categoryName} ${(g.score*100).toFixed(0)}%` };
    if (g.categoryName === "Victory") return { move: "scissors", source: "gesture", debug: `${g.categoryName} ${(g.score*100).toFixed(0)}%` };
  }

  if (lm) {
    const lmResult = classifyFromLandmarks(lm);
    lmResult.debug = g ? `${g.categoryName} ${(g.score*100).toFixed(0)}% → ${lmResult.move}` : `lm: ${lmResult.move}`;
    return lmResult;
  }

  return { move: "no hand", source: "none", debug: "" };
}

function waitForIceGatheringComplete(pc) {
  if (pc.iceGatheringState === "complete") return Promise.resolve();
  return new Promise(resolve => {
    function check() {
      if (pc.iceGatheringState === "complete") {
        pc.removeEventListener("icegatheringstatechange", check);
        resolve();
      }
    }
    pc.addEventListener("icegatheringstatechange", check);
  });
}

async function startWebRTC() {
  statusPill.textContent = "connecting...";
  pc = new RTCPeerConnection({ iceServers: [] });
  pc.addTransceiver("video", { direction: "recvonly" });
  pc.addEventListener("connectionstatechange", () => {
    const s = pc.connectionState;
    if (s === "connected") statusPill.textContent = detectorReady ? "ready" : "stream connected";
    else if (s === "connecting") statusPill.textContent = "connecting...";
    else statusPill.textContent = "disconnected";
  });
  pc.ontrack = e => {
    const [stream] = e.streams;
    piStream.srcObject = stream;
    piStream.play().catch(() => {});
  };
  const offer = await pc.createOffer();
  await pc.setLocalDescription(offer);
  await waitForIceGatheringComplete(pc);
  const res = await fetch("/offer", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ sdp: pc.localDescription.sdp, type: pc.localDescription.type })
  });
  const answer = await res.json();
  await pc.setRemoteDescription(answer);
  await new Promise(resolve => {
    if (piStream.readyState >= 2) { resolve(); return; }
    piStream.addEventListener("loadedmetadata", () => resolve(), { once: true });
  });
  await piStream.play().catch(() => {});
}

async function initDetector() {
  try {
    gestureDetail.textContent = "loading model...";
    const vision = await FilesetResolver.forVisionTasks(
      "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@latest/wasm"
    );
    gestureRecognizer = await GestureRecognizer.createFromOptions(vision, {
      baseOptions: {
        modelAssetPath: "https://storage.googleapis.com/mediapipe-models/gesture_recognizer/gesture_recognizer/float16/1/gesture_recognizer.task"
      },
      runningMode: "VIDEO",
      numHands: 1,
      minHandDetectionConfidence: 0.4,
      minHandPresenceConfidence: 0.4,
      minTrackingConfidence: 0.4
    });
    detectorReady = true;
    gestureDetail.textContent = "model ready";
    if (pc && pc.connectionState === "connected") statusPill.textContent = "ready";
    requestAnimationFrame(detectLoop);
  } catch (err) {
    console.error(err);
    statusPill.textContent = "model failed";
    gestureDetail.textContent = "refresh page";
  }
}

function drawToCanvas() {
  const sw = piStream.videoWidth, sh = piStream.videoHeight;
  if (!sw || !sh) return false;
  const ow = DETECT_WIDTH, oh = Math.round((sh / sw) * ow);
  analysisCanvas.width = ow;
  analysisCanvas.height = oh;
  ctx.save();
  ctx.clearRect(0, 0, ow, oh);
  ctx.filter = "brightness(1.05) contrast(1.05)";
  ctx.drawImage(piStream, 0, 0, ow, oh);
  ctx.restore();
  return true;
}

function lockUpdate(candidate, ts) {
  const valid = ["rock", "paper", "scissors"].includes(candidate);
  if (candidate !== "no hand") lastHandSeenAt = ts;
  if (candidate !== lastCandidate) {
    lastCandidate = candidate;
    candidateSince = ts;
  }
  const heldFor = ts - candidateSince;
  if (valid && heldFor >= LOCK_HOLD_MS) {
    currentMove = candidate;
    lastCleanLockAt = ts;
    return { previewMove: currentMove, locked: true };
  }
  if (!valid && (ts - lastCleanLockAt > RELEASE_AFTER_MS)) currentMove = "no hand";
  if (candidate === "no hand" && (ts - lastHandSeenAt > RELEASE_AFTER_MS)) currentMove = "no hand";
  return {
    previewMove: valid ? candidate : (currentMove === "no hand" ? candidate : currentMove),
    locked: false,
    holdProgress: valid ? Math.min(heldFor / LOCK_HOLD_MS, 1) : 0
  };
}

function detectLoop(ts) {
  requestAnimationFrame(detectLoop);
  if (!detectorReady) return;
  if (!piStream.videoWidth) return;
  if (ts - lastInferTime < DETECT_INTERVAL_MS) return;
  lastInferTime = ts;

  try {
    if (!drawToCanvas()) return;
    const result = gestureRecognizer.recognizeForVideo(analysisCanvas, performance.now());
    const c = classify(result);
    const ls = lockUpdate(c.move, ts);

    detectedMove.textContent = prettyMove(ls.previewMove);
    if (moveOverlay) moveOverlay.classList.toggle("locked", ls.locked);

    if (ls.locked) {
      gestureDetail.textContent = `${prettyMove(currentMove)} LOCKED`;
    } else if (c.move === "no hand") {
      gestureDetail.textContent = "show your hand";
    } else {
      gestureDetail.textContent = c.debug || "hold steady";
    }

    if (!roundBusy) setUserMove(currentMove);
  } catch (err) {
    console.error(err);
    gestureDetail.textContent = "error";
  }
}

playBtn.addEventListener("click", async () => {
  if (roundBusy) return;
  if (!["rock", "paper", "scissors"].includes(currentMove)) {
    resultText.textContent = "hold a clean rock, paper, or scissors pose first";
    return;
  }
  roundBusy = true;
  playBtn.disabled = true;
  const userMove = currentMove;
  const computerMove = impossibleMode ? COUNTERS[userMove] : ["rock", "paper", "scissors"][Math.floor(Math.random() * 3)];
  setUserMove(userMove);
  resultText.textContent = "rock... paper... scissors...";
  await animateComputer(computerMove);
  const result = decideWinner(userMove, computerMove);
  if (result === "win") score.wins += 1;
  if (result === "lose") score.losses += 1;
  if (result === "draw") score.draws += 1;
  updateScore();
  resultText.textContent = resultMessage(result, userMove, computerMove);
  playBtn.disabled = false;
  roundBusy = false;
});

resetBtn.addEventListener("click", () => {
  score.wins = 0; score.losses = 0; score.draws = 0;
  updateScore();
  resultText.textContent = "score reset";
  setComputerMove("no hand");
});

if (modeBtn) modeBtn.addEventListener("click", () => setMode(!impossibleMode));

document.addEventListener("keydown", (e) => {
  if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
  if (e.key === "i" || e.key === "I") setMode(!impossibleMode);
});

async function boot() {
  setUserMove("no hand");
  setComputerMove("no hand");
  setMode(false);
  updateScore();
  try {
    await startWebRTC();
    await initDetector();
  } catch (err) {
    console.error(err);
    statusPill.textContent = "failed";
    gestureDetail.textContent = "check pi server";
    resultText.textContent = "could not start stream";
  }
}

boot();
