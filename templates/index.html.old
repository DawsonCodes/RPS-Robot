<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RPS Robot</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <div class="space-bg" aria-hidden="true">
    <div class="stars"></div>
    <div class="nebula"></div>
  </div>

  <div class="shell">
    <header class="hero">
      <div>
        <div class="eyebrow">Raspberry Pi 5 • USB Camera • WebRTC</div>
        <h1>Rock Paper Scissors</h1>
        <p class="subtitle">
          Low-latency Pi camera stream, browser-side hand tracking, and a cleaner lock system
          so random hand motion does not constantly trigger fake moves.
        </p>
      </div>
      <div class="status-pill" id="statusPill">Starting up...</div>
    </header>

    <main class="layout">
      <section class="card camera-card">
        <div class="card-head">
          <h2>Pi Camera Feed</h2>
          <span class="note">WebRTC stream</span>
        </div>

        <div class="video-frame">
          <video id="piStream" autoplay playsinline muted></video>
        </div>

        <div class="detection-row">
          <div>
            <div class="tiny-label">Detected move</div>
            <div class="detected-text" id="detectedMove">NO HAND</div>
          </div>
          <div class="confidence-box" id="gestureDetail">Loading hand model...</div>
        </div>
      </section>

      <section class="card game-card">
        <div class="card-head">
          <h2>Game Arena</h2>
          <span class="note">browser-side logic</span>
        </div>

        <div class="arena">
          <div class="player-box">
            <div class="player-name">You</div>
            <div class="hand big" id="userHand">❔</div>
            <div class="move-label" id="userMoveLabel">waiting...</div>
          </div>

          <div class="versus">VS</div>

          <div class="player-box glow">
            <div class="player-name">Computer</div>
            <div class="hand huge" id="computerHand">❔</div>
            <div class="move-label" id="computerMoveLabel">press play</div>
          </div>
        </div>

        <div class="actions">
          <button id="playBtn">Play Round</button>
          <button id="resetBtn" class="ghost">Reset Score</button>
        </div>

        <button id="modeBtn" class="mode-btn ghost">Mode: Fair</button>

        <div class="score-grid">
          <div class="score-card">
            <span>Wins</span>
            <strong id="winsCount">0</strong>
          </div>
          <div class="score-card">
            <span>Losses</span>
            <strong id="lossesCount">0</strong>
          </div>
          <div class="score-card">
            <span>Draws</span>
            <strong id="drawsCount">0</strong>
          </div>
        </div>

        <div class="result-panel">
          <div class="tiny-label">Result</div>
          <div id="resultText">Show rock, paper, or scissors to the Pi camera.</div>
        </div>
      </section>
    </main>
  </div>

  <canvas id="analysisCanvas" hidden></canvas>
  <script type="module" src="/static/app.js"></script>
</body>
</html>
